def rollout_mse(predict_fn, true_fn, initial_conditions, N=50):
    mses = []
    for ic in initial_conditions:
        true = true_fn(*ic, N)             # (N+1, 4)
        pred = predict_fn(*ic, N)          # (N+1, ?)
        # Compare on raw [x, xd, theta, thetad] — convert aug back if needed
        mses.append(np.mean((true - pred)**2, axis=0))  # per-dimension MSE
    return np.array(mses)   # (n_ics, state_dim)

