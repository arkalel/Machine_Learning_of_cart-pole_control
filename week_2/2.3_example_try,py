def jax_remap_angle(theta):
    return (theta + jnp.pi) % (2 * jnp.pi) - jnp.pi

def jaxRollout(cart_position, cart_velocity, pole_angle, pole_velocity, N=200):
    rollout_system = CartPole(visual=False)

    # Initialise state as a JAX array
    state = jnp.array([cart_position, cart_velocity, pole_angle, pole_velocity], dtype=float)
    rollout_system.setState(state.tolist())

    rollout_simulation = [jnp.array(rollout_system.getState())]
    for _ in range(N):
        rollout_system.performAction()

        current_state = jnp.array(rollout_system.getState())
        current_state = current_state.at[2].set(jax_remap_angle(current_state[2]))
        rollout_system.setState(current_state.tolist())

        rollout_simulation.append(current_state)

    # Stack once outside the loop — no jnp.append
    return jnp.stack(rollout_simulation)   # shape (N+1, 4)

def augment_state(state):
    state = jnp.asarray(state, dtype=float)
    if state.ndim == 1:
        x, xd, theta, thetad = state
        return jnp.array([x, xd, jnp.sin(theta), jnp.cos(theta), thetad])
    else:  # (N, 4) batch
        return jnp.column_stack([
            state[:, 0],
            state[:, 1],
            jnp.sin(state[:, 2]),
            jnp.cos(state[:, 2]),
            state[:, 3],
        ])

def randomstate():
    cart_position = random.uniform(-10, 10)
    cart_velocity = random.uniform(-10, 10)
    pole_angle = random.uniform(-np.pi, np.pi)
    pole_velocity = random.uniform(-15, 15)
    random_state = [cart_position, cart_velocity, pole_angle, pole_velocity]
    return random_state

def augLinRegCoefficients(N=500):
    X_system = CartPole(visual=False)
    state_pairs = []

    for _ in range(N):
        # Raw random state
        raw_X = jnp.array(randomstate())
        X_system.setState(raw_X.tolist())
        X_system.performAction()
        raw_Y = jnp.array(X_system.getState())

        aug_X = augment_state(raw_X)   # (5,)
        aug_Y = augment_state(raw_Y)   # (5,)
        delta = aug_Y - aug_X          # (5,) — no remapping needed

        state_pairs.append(jnp.hstack([aug_X, delta]))

    state_pairs = jnp.stack(state_pairs)   # (N, 10)
    X = np.array(state_pairs[:, :5])
    Y = np.array(state_pairs[:, 5:])

    model = LinearRegression(fit_intercept=False)
    model.fit(X, Y)
    C = jnp.array(model.coef_)            # (5, 5)
    return C, state_pairs

def augTimeEvolution(cart_position, cart_velocity, pole_angle, pole_velocity, N=200):
    C, _ = augLinRegCoefficients()

    X = augment_state(
        jnp.array([cart_position, cart_velocity, pole_angle, pole_velocity])
    )  # (5,)

    predicted_states = [X]
    for _ in range(N):
        X = C @ X + X          # ← matches jaxTimeEvolution: X = C @ X + X
        predicted_states.append(X)

    return jnp.stack(predicted_states)                 # (N+1, 5)

@jax.jit
def aug_kernel_matrix(X, C, sigmas):

    diff_sq  = (X[:, None, :] - C[None, :, :]) ** 2   # (N, M, 5)
    exponent = jnp.sum(diff_sq / (2 * sigmas ** 2), axis=-1)
    return jnp.exp(-exponent)


def augLinRegData(N=1600):
    _, pairs = augLinRegCoefficients(N)
    X = pairs[:, :5]
    Y = pairs[:, 5:]
    return X, Y


def augNonLinearModel(X_train, Y_train, M, state_variable, lamda, sigmas):
    N_train = X_train.shape[0]
    indices = np.random.choice(N_train, M, replace=False)
    centres = X_train[indices]   # (M, 5)

    K_NM = aug_kernel_matrix(X_train, centres, sigmas)   # (N, M)
    K_MM = aug_kernel_matrix(centres, centres, sigmas)   # (M, M)

    A     = K_NM.T @ K_NM + lamda * K_MM
    b     = K_NM.T @ Y_train[:, state_variable]
    alpha = jnp.linalg.solve(A, b)
    return alpha, centres


def augHyperparameterMSE(params, X_train, Y_train, X_val, Y_val, centres_stacked):
    lamda  = params[0]
    sigmas = params[1:]   # (5,)

    total_mse = 0.0
    for d in range(5):
        centres = centres_stacked[d]   # (M, 5)

        K_NM  = aug_kernel_matrix(X_train, centres, sigmas)
        K_MM  = aug_kernel_matrix(centres, centres, sigmas)
        K_val = aug_kernel_matrix(X_val,   centres, sigmas)

        A     = K_NM.T @ K_NM + lamda * K_MM
        b     = K_NM.T @ Y_train[:, d]
        alpha = jnp.linalg.solve(A, b)

        Y_pred     = K_val @ alpha
        total_mse += jnp.mean((Y_pred - Y_val[:, d]) ** 2)

    return total_mse / 5.0


def augFitNonLinearModel(N_train=1600, N_val=200, M=320, lamda=0.001):
    # Generate augmented training and validation data
    C_lin, train_pairs = augLinRegCoefficients(N_train)
    _,     val_pairs   = augLinRegCoefficients(N_val)

    X_train = train_pairs[:, :5]
    Y_train = train_pairs[:, 5:]
    X_val   = val_pairs[:, :5]
    Y_val   = val_pairs[:, 5:]

    # Fixed centres — one set per output dimension
    centres_list = []
    for _ in range(5):
        idx = np.random.choice(X_train.shape[0], M, replace=False)
        centres_list.append(X_train[idx])
    centres_stacked = jnp.stack(centres_list)   # (5, M, 5)

    # Initial hyperparameters
    init_sigmas = jnp.std(X_train, axis=0)      # (5,)
    x0          = jnp.hstack([lamda, init_sigmas])

    grad_func = jax.jit(jax.grad(augHyperparameterMSE, argnums=0))
    bnds = [(1e-6, 0.1)] + [(1e-6, 20)] * 5

    result = scipy.optimize.minimize(
        augHyperparameterMSE,
        x0,
        args=(X_train, Y_train, X_val, Y_val, centres_stacked),
        method='L-BFGS-B',
        jac=lambda p, *a: np.array(grad_func(jnp.array(p), *a)),
        bounds=bnds,
        options={'maxiter': 200, 'ftol': 1e-9},
    )

    opt_params = jnp.array(result.x)
    opt_lamda  = opt_params[0]
    opt_sigmas = opt_params[1:]

    print(f"Initial  val MSE : {augHyperparameterMSE(x0, X_train, Y_train, X_val, Y_val, centres_stacked):.6f}")
    print(f"Optimal  val MSE : {augHyperparameterMSE(opt_params, X_train, Y_train, X_val, Y_val, centres_stacked):.6f}")
    print(f"Optimised lambda : {float(opt_lamda):.6f}")
    print(f"Optimised sigmas : {np.array(opt_sigmas)}")

    # Refit alphas with optimal hyperparameters, store in (5, M) array
    alphas_list = []
    for d in range(5):
        centres = centres_stacked[d]  # reuse set A
        K_NM = aug_kernel_matrix(X_train, centres, opt_sigmas)
        K_MM = aug_kernel_matrix(centres, centres, opt_sigmas)
        A = K_NM.T @ K_NM + opt_lamda * K_MM
        b = K_NM.T @ Y_train[:, d]
        alphas_list.append(jnp.linalg.solve(A, b))
    alphas = jnp.stack(alphas_list)

    return alphas, centres_stacked, opt_sigmas


@jax.jit
def aug_single_state_prediction(
    X_new,    # (5,)
    centres,  # (M, 5)
    sigmas,   # (5,)
    alphas,   # (M,)
):
    k = aug_kernel_matrix(X_new[None, :], centres, sigmas)[0]  # (M,)
    return k @ alphas


@jax.jit
def aug_next_state(
    X,                # (5,)
    centres_stacked,  # (5, M, 5)
    sigmas,           # (5,)
    alphas,           # (5, M)
):
    # Exactly mirrors jax_next_state
    predict_dim = lambda c, a: aug_single_state_prediction(X, c, sigmas, a)
    return jax.vmap(predict_dim)(centres_stacked, alphas)  # (5,)


@functools.partial(jax.jit, static_argnums=(4,))
def augNonLinearEvolution(
    cart_position, cart_velocity, pole_angle, pole_velocity,
    steps,
    alphas,           # (5, M)
    centres_stacked,  # (5, M, 5)
    sigmas,           # (5,)
):
    X0 = augment_state(
        jnp.array([cart_position, cart_velocity, pole_angle, pole_velocity])
    )  # (5,)

    def step(X, _):
        delta  = aug_next_state(X, centres_stacked, sigmas, alphas)
        X_next = X + delta
        norm = jnp.sqrt(X_next[2] * 2 + X_next[3] * 2)
        X_next = X_next.at[2].set(X_next[2] / norm)
        X_next = X_next.at[3].set(X_next[3] / norm)
        return X_next, X_next   # (carry, output)

    _, traj = jax.lax.scan(step, X0, None, length=steps)
    return jnp.vstack([X0[None, :], traj])   # (steps+1, 5)


