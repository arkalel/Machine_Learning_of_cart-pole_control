def rawLinRegCoefficients(N=500):
    X_system = CartPole(visual=False)
    state_pairs = []

    for _ in range(N):
        raw_X = jnp.array(randomstate())
        X_system.setState(raw_X.tolist())
        X_system.performAction()
        raw_Y = jnp.array(X_system.getState())

        raw_Y = raw_Y.at[2].set(jax_remap_angle(raw_Y[2]))


        delta = raw_Y - raw_X
        delta = delta.at[2].set(jax_remap_angle(delta[2]))

        state_pairs.append(jnp.hstack([raw_X, delta]))

    state_pairs = jnp.stack(state_pairs)
    X = np.array(state_pairs[:, :4])
    Y = np.array(state_pairs[:, 4:])

    model = LinearRegression(fit_intercept=False)
    model.fit(X, Y)
    C = jnp.array(model.coef_)  # Shape: (4, 4)
    return C, state_pairs


def rawTimeEvolution(cart_position, cart_velocity, pole_angle, pole_velocity, N=200):
    C, _ = rawLinRegCoefficients()
    X = jnp.array([cart_position, cart_velocity, pole_angle, pole_velocity])

    predicted_states = [X]
    for _ in range(N):
        X = C @ X + X
        X = X.at[2].set(jax_remap_angle(X[2]))  # Map back to standard [-pi, pi] manifold
        predicted_states.append(X)

    return jnp.stack(predicted_states)  # Shape: (N+1, 4)

@jax.jit
def raw_kernel_matrix(X, C, sigmas):
    diff_sq = (X[:, None, :] - C[None, :, :]) ** 2  # Shape: (N, M, 4)
    exponent = jnp.sum(diff_sq / (2 * sigmas ** 2), axis=-1)
    return jnp.exp(-exponent)


def rawHyperparameterMSE(params, X_train, Y_train, X_val, Y_val, centres_stacked):
    lamda = params[0]
    sigmas = params[1:]  # Shape: (4,)

    total_mse = 0.0
    for d in range(4):
        centres = centres_stacked[d]

        K_NM = raw_kernel_matrix(X_train, centres, sigmas)
        K_MM = raw_kernel_matrix(centres, centres, sigmas)
        K_val = raw_kernel_matrix(X_val, centres, sigmas)

        A = K_NM.T @ K_NM + lamda * K_MM
        b = K_NM.T @ Y_train[:, d]
        alpha = jnp.linalg.solve(A, b)

        Y_pred = K_val @ alpha
        total_mse += jnp.mean((Y_pred - Y_val[:, d]) ** 2)

    return total_mse / 4.0


def rawFitNonLinearModel(N_train=1600, N_val=200, M=320, lamda=0.001):
    C_lin, train_pairs = rawLinRegCoefficients(N_train)
    _, val_pairs = rawLinRegCoefficients(N_val)

    X_train = train_pairs[:, :4]
    Y_train = train_pairs[:, 4:]
    X_val = val_pairs[:, :4]
    Y_val = val_pairs[:, 4:]

    centres_list = []
    for _ in range(4):
        idx = np.random.choice(X_train.shape[0], M, replace=False)
        centres_list.append(X_train[idx])
    centres_stacked = jnp.stack(centres_list)  # Shape: (4, M, 4)

    init_sigmas = jnp.std(X_train, axis=0)  # Shape: (4,)
    x0 = jnp.hstack([lamda, init_sigmas])

    grad_func = jax.jit(jax.grad(rawHyperparameterMSE, argnums=0))
    bnds = [(1e-6, 0.1)] + [(1e-6, 20)] * 4

    result = scipy.optimize.minimize(
        rawHyperparameterMSE,
        x0,
        args=(X_train, Y_train, X_val, Y_val, centres_stacked),
        method='L-BFGS-B',
        jac=lambda p, *a: np.array(grad_func(jnp.array(p), *a)),
        bounds=bnds,
        options={'maxiter': 200, 'ftol': 1e-9},
    )

    opt_params = jnp.array(result.x)
    opt_lamda = opt_params[0]
    opt_sigmas = opt_params[1:]

    alphas_list = []
    for d in range(4):
        centres = centres_stacked[d]
        K_NM = raw_kernel_matrix(X_train, centres, opt_sigmas)
        K_MM = raw_kernel_matrix(centres, centres, opt_sigmas)
        A = K_NM.T @ K_NM + opt_lamda * K_MM
        b = K_NM.T @ Y_train[:, d]
        alphas_list.append(jnp.linalg.solve(A, b))
    alphas = jnp.stack(alphas_list)  # Shape: (4, M)

    return alphas, centres_stacked, opt_sigmas


@jax.jit
def raw_single_state_prediction(X_new, centres, sigmas, alphas):
    k = raw_kernel_matrix(X_new[None, :], centres, sigmas)[0]
    return k @ alphas


@jax.jit
def raw_next_state(X, centres_stacked, sigmas, alphas):
    predict_dim = lambda c, a: raw_single_state_prediction(X, c, sigmas, a)
    return jax.vmap(predict_dim)(centres_stacked, alphas)


@functools.partial(jax.jit, static_argnums=(4,))
def rawNonLinearEvolution(
        cart_position, cart_velocity, pole_angle, pole_velocity,
        steps,
        alphas,  # Shape: (4, M)
        centres_stacked,  # Shape: (4, M, 4)
        sigmas,  # Shape: (4,)
):
    X0 = jnp.array([cart_position, cart_velocity, pole_angle, pole_velocity])

    def step(X, _):
        delta = raw_next_state(X, centres_stacked, sigmas, alphas)
        X_next = X + delta
        X_next = X_next.at[2].set(jax_remap_angle(X_next[2]))
        return X_next, X_next

    _, traj = jax.lax.scan(step, X0, None, length=steps)
    return jnp.vstack([X0[None, :], traj])  # Shape: (steps+1, 4)


def raw_linear_predict_fn(x, xd, theta, thetad, N):
    return np.array(rawTimeEvolution(x, xd, theta, thetad, N))

def raw_nonlinear_predict_fn(x, xd, theta, thetad, N):
    return np.array(rawNonLinearEvolution(x, xd, theta, thetad, N,
                                          raw_alphas, raw_centres, raw_sigmas))


