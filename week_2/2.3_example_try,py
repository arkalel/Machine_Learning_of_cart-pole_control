def aug_to_raw(aug_traj):
    """(N+1, 5) augmented -> (N+1, 4) raw"""
    x      = aug_traj[:, 0]
    xd     = aug_traj[:, 1]
    theta  = np.arctan2(aug_traj[:, 2], aug_traj[:, 3])  # recover angle
    thetad = aug_traj[:, 4]
    return np.stack([x, xd, theta, thetad], axis=1)



