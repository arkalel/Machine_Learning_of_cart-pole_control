def jaxLinRegCoefficients(N=500):
    # Initialise system
    X_system = CartPole(visual=False)

    state_pairs = []
    for step in range(N):
        X_state = jnp.array(randomstate())
        X_state_list = X_state[:4].tolist()
        X_system.setState(X_state_list)
        X_system.performAction()
        New_state = jnp.array(X_system.getState())
        New_state = jnp.hstack((New_state, X_state[4]))

        # Y defined as the change between the two states
        Y_change = New_state - X_state
        Y_change = Y_change.at[2].set(jax_remap_angle(Y_change[2]))

        XY_pair = jnp.hstack((X_state, Y_change))
        state_pairs.append(XY_pair)

    # Stack once outside the loop — no jnp.append
    state_pairs = jnp.stack(state_pairs)

    X = state_pairs[:, :4]
    Y = state_pairs[:, 4:]

    # Linear regression
    model = LinearRegression()
    model.fit(X, Y)
    coefficients = model.coef_
    return coefficients, state_pairs

def jaxTimeEvolution(cart_position, cart_velocity, pole_angle, pole_velocity, N=200):
    # Get linear regression coefficients
    C, _ = jaxLinRegCoefficients()

    # Initialise state as a JAX array
    X = jnp.array([cart_position, cart_velocity, pole_angle, pole_velocity], dtype=float)

    predicted_states = [X]
    for _ in range(N):
        X = C @ X + X
        X = X.at[2].set(jax_remap_angle(X[2]))
        predicted_states.append(X)

    # Stack once outside the loop — no jnp.vstack in loop
    return jnp.stack(predicted_states)   # shape (N+1, 4)


